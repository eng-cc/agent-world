# Example resource pack for viewer-texture-inspector.sh
#
# Naming rules:
# 1) Entity-level key:
#    TEXTURE_INSPECTOR_RESOURCE_<ENTITY>_<FIELD>=<asset_path>
# 2) Variant-level key (higher priority than entity-level):
#    TEXTURE_INSPECTOR_RESOURCE_<ENTITY>_<VARIANT>_<FIELD>=<asset_path>
#
# ENTITY: AGENT | LOCATION | ASSET | POWER_PLANT | POWER_STORAGE
# VARIANT: DEFAULT | MATTE | GLOSSY
# FIELD:
#   MESH_ASSET
#   BASE_TEXTURE_ASSET
#   NORMAL_TEXTURE_ASSET
#   METALLIC_ROUGHNESS_TEXTURE_ASSET
#   EMISSIVE_TEXTURE_ASSET

# Power plant (entity-level baseline)
TEXTURE_INSPECTOR_RESOURCE_POWER_PLANT_MESH_ASSET=assets/models/props/power_plant_hero.glb
TEXTURE_INSPECTOR_RESOURCE_POWER_PLANT_BASE_TEXTURE_ASSET=assets/textures/power_plant/power_plant_base.png
TEXTURE_INSPECTOR_RESOURCE_POWER_PLANT_NORMAL_TEXTURE_ASSET=assets/textures/power_plant/power_plant_normal.png
TEXTURE_INSPECTOR_RESOURCE_POWER_PLANT_METALLIC_ROUGHNESS_TEXTURE_ASSET=assets/textures/power_plant/power_plant_mr.png

# Power plant matte override (variant-level)
TEXTURE_INSPECTOR_RESOURCE_POWER_PLANT_MATTE_BASE_TEXTURE_ASSET=assets/textures/power_plant/power_plant_matte_base.png

# Power storage (entity-level baseline)
TEXTURE_INSPECTOR_RESOURCE_POWER_STORAGE_MESH_ASSET=assets/models/props/power_storage_hero.glb
TEXTURE_INSPECTOR_RESOURCE_POWER_STORAGE_BASE_TEXTURE_ASSET=assets/textures/power_storage/power_storage_base.png
TEXTURE_INSPECTOR_RESOURCE_POWER_STORAGE_NORMAL_TEXTURE_ASSET=assets/textures/power_storage/power_storage_normal.png
TEXTURE_INSPECTOR_RESOURCE_POWER_STORAGE_METALLIC_ROUGHNESS_TEXTURE_ASSET=assets/textures/power_storage/power_storage_mr.png
